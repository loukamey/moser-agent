# ============================================
# EMAIL - OUTLOOK
# ============================================
def send_email(subject, body):
    msg = MIMEMultipart()
    msg["From"] = EMAIL_SENDER
    msg["To"] = EMAIL_RECEIVER
    msg["Subject"] = subject
    msg.attach(MIMEText(body, "plain"))
    try:
        with smtplib.SMTP("smtp.office365.com", 587) as server:
            server.starttls()
            server.login(EMAIL_SENDER, EMAIL_PASSWORD)
            server.send_message(msg)
        print(f"✅ Email sent: {subject}")
    except Exception as e:
        print(f"❌ Email error: {e}")

# ============================================
# DAILY JOB - Runs every day at 8am Dubai
# ============================================
def daily_job():
    print(f"🔍 Running daily scan - {datetime.now()}")
    listings = scrape_moser_watches()
    auctions = scrape_auction_results()
    all_found = listings + auctions
    
    if all_found:
        save_to_monthly_log(all_found)
        analysis = daily_analysis(listings, auctions)
        send_email(
            f"⌚ Moser Daily Alert - {datetime.now().strftime('%B %d, %Y')}",
            analysis
        )
        print(f"Found {len(all_found)} listings today")
    else:
        print("No new listings found today")

# ============================================
# MONTHLY JOB - Runs on 1st of each month
# ============================================
def monthly_job():
    print(f"📊 Running monthly analysis - {datetime.now()}")
    all_data = load_monthly_log()
    if all_data:
        analysis = monthly_analysis(all_data)
        send_email(
            f"📊 Moser Monthly Market Report - {datetime.now().strftime('%B %Y')}",
            analysis
        )
        clear_monthly_log()
        print("Monthly report sent and log cleared")
    else:
        print("No data collected this month")

# ============================================
# SCHEDULER - Dubai time is UTC+4
# So 8am Dubai = 4am UTC
# ============================================
schedule.every().day.at("04:00").do(daily_job)
schedule.every().monday.at("04:00").do(
    lambda: datetime.now().day <= 7 and monthly_job()
)

print("✅ H. Moser & Cie Watch Agent is running!")
print(f"📅 Daily alerts: every day at 8:00am Dubai time")
print(f"📊 Monthly report: first Monday of each month")
print(f"Started at: {datetime.now()}")

while True:
    schedule.run_pending()
    time.sleep(60)
