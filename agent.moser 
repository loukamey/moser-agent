# CLAUDE DAILY ANALYSIS
# ============================================
def daily_analysis(listings, auctions):
    client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)
    
    prompt = f"""You are a professional watch market analyst specializing in H. Moser & Cie.

Today's date: {datetime.now().strftime("%B %d, %Y")}

NEW SECONDARY MARKET LISTINGS TODAY:
{json.dumps(listings, indent=2)}

LATEST AUCTION RESULTS:
{json.dumps(auctions, indent=2)}

Write a SHORT, sharp daily briefing (5 minute read) for a serious collector/dealer covering:
- 🆕 New pieces that appeared today (reference number, price, source)
- 🏆 Any auction results worth noting
- ⚡ Any unusual pricing or rare references spotted
- 💡 One quick market observation

Be concise, professional, and direct. No fluff."""

    message = client.messages.create(
        model="claude-sonnet-4-20250514",
        max_tokens=800,
        messages=[{"role": "user", "content": prompt}]
    )
    return message.content[0].text

